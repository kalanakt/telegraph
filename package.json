{
  "name": "telegram-bot-builder",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.2.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @telegram-builder/shared build",
    "typecheck": "pnpm exec tsc -p packages/shared/tsconfig.json --noEmit && pnpm exec tsc -p apps/worker/tsconfig.json --noEmit && pnpm exec tsc -p apps/web/tsconfig.json --noEmit",
    "ci:verify": "pnpm prisma:generate && pnpm typecheck && pnpm test && pnpm build",
    "railway:build:web": "pnpm build:shared && pnpm --filter web build",
    "railway:start:web": "pnpm --filter web start",
    "railway:build:worker": "pnpm exec prisma generate && pnpm build:shared && pnpm --filter worker build",
    "railway:start:worker": "pnpm --filter worker start",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "migrate:flow-backfill": "pnpm tsx scripts/backfill-rule-flow-definitions.ts",
    "db:reset:v2": "./scripts/reset-v2-db.sh"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.5.0",
    "prisma": "^7.5.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "^5.10.0"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
