generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum BotStatus {
  active
  invalid_token
  webhook_error
  paused
}

enum ActionStatus {
  pending
  succeeded
  failed
}

enum ConversationSessionStatus {
  ACTIVE
  PAUSED
  HANDOFF
  CLOSED
}

enum SessionCheckpointStatus {
  OPEN
  RESUMED
  EXPIRED
  CANCELED
}

enum CommerceOrderStatus {
  draft
  awaiting_shipping
  awaiting_payment
  paid
  fulfilled
  canceled
}

enum TemplateVisibility {
  PRIVATE
  PUBLIC
}

model User {
  id            String         @id @default(cuid())
  clerkUserId   String         @unique
  email         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscription  Subscription?
  bots          Bot[]
  workflowRules WorkflowRule[]
  workflowTemplates WorkflowTemplate[]
  workflowRuns  WorkflowRun[]
}

model Subscription {
  id                 String           @id @default(cuid())
  userId             String           @unique
  creemCustomerId     String?         @unique
  creemSubscriptionId String?         @unique
  creemProductId      String?
  plan               SubscriptionPlan @default(FREE)
  status             String           @default("inactive")
  activeAt           DateTime?
  pastDueAt          DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bot {
  id                String          @id @default(cuid())
  userId            String
  telegramBotId     BigInt
  username          String?
  displayName       String?
  encryptedToken    String
  encryptedCryptoPayToken String?
  encryptedCryptoPayWebhookSecret String?
  cryptoPayAppId    String?
  cryptoPayAppName  String?
  cryptoPayUseTestnet Boolean      @default(false)
  cryptoPayConnectedAt DateTime?
  status            BotStatus       @default(active)
  captureUsersEnabled Boolean       @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowRules     WorkflowRule[]
  incomingEvents    IncomingEvent[]
  workflowRuns      WorkflowRun[]
  botUsers          BotUser[]
  conversationSessions ConversationSession[]
  customerProfiles  CustomerProfile[]
  commerceOrders    CommerceOrder[]

  @@unique([userId, telegramBotId])
}

model BotUser {
  id               String   @id @default(cuid())
  botId            String
  telegramUserId   BigInt
  username         String?
  firstName        String?
  lastName         String?
  languageCode     String?
  firstSeenAt      DateTime
  lastSeenAt       DateTime
  interactionCount Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bot              Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, telegramUserId])
  @@index([botId, lastSeenAt])
}

model ConversationSession {
  id                 String                    @id @default(cuid())
  botId              String
  chatId             String
  telegramUserId     BigInt?
  customerProfileId  String?
  status             ConversationSessionStatus @default(ACTIVE)
  context            Json
  startedAt          DateTime                  @default(now())
  lastEventAt        DateTime                  @default(now())
  pausedAt           DateTime?
  handedOffAt        DateTime?
  handoffOwner       String?
  handoffNote        String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  bot                Bot                       @relation(fields: [botId], references: [id], onDelete: Cascade)
  customerProfile    CustomerProfile?          @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  checkpoints        SessionCheckpoint[]
  workflowRuns       WorkflowRun[]
  commerceOrders     CommerceOrder[]

  @@unique([botId, chatId, telegramUserId])
  @@index([botId, status, lastEventAt])
}

model SessionCheckpoint {
  id                    String                  @id @default(cuid())
  sessionId             String
  workflowRunId         String?
  ruleId                String
  nodeId                String
  checkpointType        String
  status                SessionCheckpointStatus @default(OPEN)
  resumeKey             String?
  metadata              Json
  expiresAt             DateTime?
  resolvedAt            DateTime?
  resumeEventId         String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  session               ConversationSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workflowRun           WorkflowRun?            @relation("RunCreatedCheckpoints", fields: [workflowRunId], references: [id], onDelete: SetNull)
  rule                  WorkflowRule            @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  resumeEvent           IncomingEvent?          @relation(fields: [resumeEventId], references: [id], onDelete: SetNull)
  resumedRuns           WorkflowRun[]           @relation("RunResumedFromCheckpoint")

  @@index([sessionId, status, createdAt])
  @@index([ruleId, status, createdAt])
  @@index([resumeKey, status])
}

model CustomerProfile {
  id                 String               @id @default(cuid())
  botId              String
  telegramUserId     BigInt
  chatId             String?
  username           String?
  firstName          String?
  lastName           String?
  languageCode       String?
  phoneNumber        String?
  email              String?
  tags               Json
  attributes         Json
  lastInteractionAt  DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  bot                Bot                  @relation(fields: [botId], references: [id], onDelete: Cascade)
  conversationSessions ConversationSession[]
  workflowRuns       WorkflowRun[]
  commerceOrders     CommerceOrder[]

  @@unique([botId, telegramUserId])
  @@index([botId, updatedAt])
}

model CommerceOrder {
  id                 String              @id @default(cuid())
  botId              String
  sessionId          String?
  customerProfileId  String?
  latestWorkflowRunId String?
  externalId         String?
  invoicePayload     String?
  currency           String?
  totalAmount        Int?
  shippingOptionId   String?
  shippingAddress    Json
  orderInfo          Json
  attributes         Json
  status             CommerceOrderStatus @default(draft)
  paidAt             DateTime?
  fulfilledAt        DateTime?
  canceledAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bot                Bot                 @relation(fields: [botId], references: [id], onDelete: Cascade)
  session            ConversationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  customerProfile    CustomerProfile?    @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  workflowRuns       WorkflowRun[]

  @@index([botId, status, updatedAt])
  @@index([invoicePayload])
  @@unique([botId, externalId])
}

model WorkflowRule {
  id           String            @id @default(cuid())
  userId       String
  botId        String
  name         String
  trigger      String
  flowDefinition Json
  enabled      Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot          Bot               @relation(fields: [botId], references: [id], onDelete: Cascade)
  webhookEndpoint FlowWebhookEndpoint?
  conditions   RuleCondition[]
  actions      RuleAction[]
  workflowRuns WorkflowRun[]
  checkpoints  SessionCheckpoint[]

  @@index([botId, trigger, enabled])
}

model FlowWebhookEndpoint {
  id                  String       @id @default(cuid())
  ruleId               String       @unique
  endpointId           String       @unique
  encryptedSecret      String?
  signatureHeaderName  String?
  enabled              Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  rule                 WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model RuleCondition {
  id        String   @id @default(cuid())
  ruleId    String
  type      String
  payload   Json
  order     Int
  createdAt DateTime @default(now())
  rule      WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, order])
}

model RuleAction {
  id        String   @id @default(cuid())
  ruleId    String
  type      String
  payload   Json
  order     Int
  createdAt DateTime @default(now())
  rule      WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, order])
}

model IncomingEvent {
  id             String   @id @default(cuid())
  botId          String
  idempotencyKey String   @unique
  updateId       Int
  payload        Json
  createdAt      DateTime @default(now())
  bot            Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  workflowRuns   WorkflowRun[]
  resumedCheckpoints SessionCheckpoint[]

  @@index([botId, createdAt])
}

model WorkflowRun {
  id           String       @id @default(cuid())
  userId       String
  botId        String
  ruleId       String
  eventId      String
  conversationSessionId String?
  customerProfileId String?
  commerceOrderId String?
  resumedFromCheckpointId String?
  status       String       @default("pending")
  trigger      String
  eventPayload Json
  contextVariables Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot          Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)
  rule         WorkflowRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  event        IncomingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  conversationSession ConversationSession? @relation(fields: [conversationSessionId], references: [id], onDelete: SetNull)
  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  commerceOrder CommerceOrder? @relation(fields: [commerceOrderId], references: [id], onDelete: SetNull)
  resumedFromCheckpoint SessionCheckpoint? @relation("RunResumedFromCheckpoint", fields: [resumedFromCheckpointId], references: [id], onDelete: SetNull)
  actionRuns   ActionRun[]
  createdCheckpoints SessionCheckpoint[] @relation("RunCreatedCheckpoints")

  @@index([botId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationSessionId, createdAt])
}

model ActionRun {
  id           String       @id @default(cuid())
  workflowRunId String
  actionId     String
  type         String
  payload      Json
  status       ActionStatus @default(pending)
  attempt      Int          @default(0)
  lastError    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  workflowRun  WorkflowRun  @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, createdAt])
  @@unique([workflowRunId, actionId])
}

model WorkflowTemplate {
  id                String             @id @default(cuid())
  userId            String
  title             String
  slug              String             @unique
  description       String?
  visibility        TemplateVisibility @default(PRIVATE)
  publishedVersionId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  draftFlows        WorkflowTemplateDraftFlow[]
  versions          WorkflowTemplateVersion[]

  @@index([userId, createdAt])
  @@index([visibility, updatedAt])
}

model WorkflowTemplateDraftFlow {
  id             String           @id @default(cuid())
  templateId     String
  name           String
  trigger        String
  flowDefinition Json
  sortOrder      Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  template       WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model WorkflowTemplateVersion {
  id          String                      @id @default(cuid())
  templateId  String
  version     Int
  title       String
  description String?
  createdAt   DateTime                    @default(now())
  template    WorkflowTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flows       WorkflowTemplateVersionFlow[]

  @@unique([templateId, version])
  @@index([templateId, createdAt])
}

model WorkflowTemplateVersionFlow {
  id                String                  @id @default(cuid())
  templateVersionId String
  name              String
  trigger           String
  flowDefinition    Json
  sortOrder         Int
  createdAt         DateTime                @default(now())
  templateVersion   WorkflowTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)

  @@index([templateVersionId, sortOrder])
}
