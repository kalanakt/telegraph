DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_bot_builder
REDIS_URL=redis://localhost:6379
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
ENCRYPTION_KEY=please_change_me_to_32_chars_minimum
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com/api/telegram/webhook
# Optional but strongly recommended for production.
# When set, Telegraph will configure Telegram webhooks with a secret token and verify
# incoming webhook requests via the `X-Telegram-Bot-Api-Secret-Token` header.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
NEXT_PUBLIC_SITE_URL=https://telegraph.us.com
SENTRY_DSN=
# Optional. Set to a decimal like 0.1 to enable performance tracing.
SENTRY_TRACES_SAMPLE_RATE=0
# Optional. Defaults to NODE_ENV when unset.
SENTRY_ENVIRONMENT=

# Creem (Merchant of Record)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
# Product id for your PRO subscription product (e.g. prod_XXXXX)
CREEM_PRO_PRODUCT_ID=
# Optional override (otherwise inferred from CREEM_API_KEY prefix).
CREEM_TEST_MODE=false

# S3-compatible object storage (Railway/Tigris)
S3_ENDPOINT=https://t3.storageapi.dev
S3_REGION=auto
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for uploaded files (defaults to S3_ENDPOINT/S3_BUCKET if unset)
S3_PUBLIC_URL=
